                      "cornerRadius": 8,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "$--border"
                      },
                      "layout": "vertical",
                      "padding": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "kjjsk",
                          "name": "usageCodeText",
                          "fill": "$--text-primary",
                          "content": "val interactionState = remember { MutableInteractionState() }\n\nContainer(\n    modifier = Modifier\n        .interactionState(interactionState),\n) {\n    // Read state reactively\n    val isFocused = interactionState.isFocused\n    val isHovered = interactionState.isHovered\n    val isPressed = interactionState.isPressed\n    val isSelected = interactionState.isSelected\n\n    Text(\"Focused: $isFocused\")\n}",
                          "lineHeight": 1.5,
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
